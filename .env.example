# ============================================================
# Máximo Respeito — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais:
#   cp .env.example .env
# ============================================================

# Supabase (usado pelo SDK @supabase/supabase-js na API)
# Dashboard: Project Settings > API
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# API
NODE_ENV=development
PORT=3333

# Painel admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_TOKEN_SECRET=troque-por-um-segredo-com-pelo-menos-16-caracteres

# Frontend (Vite — prefixo VITE_ é obrigatório)
# Dev local (API separada em :3333): http://localhost:3333
# Netlify (deploy ou `npm run dev:netlify`): deixe vazio para usar a mesma origem
VITE_API_URL=http://localhost:3333
